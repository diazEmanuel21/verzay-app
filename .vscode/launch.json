{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Next.js Debug (Server Actions + RSC)",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "node",
        "runtimeArgs": [
          "--inspect-brk",
          "node_modules/next/dist/bin/next",
          "dev"
        ],
        "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
        "sourceMaps": true,
        "env": {
          "NODE_OPTIONS": "--enable-source-maps"
        },
        "cwd": "${workspaceFolder}"
      }
    ]
  }
  