generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String             @unique
  password           String?
  emailVerified      DateTime?
  image              String?
  role               Role               @default(user)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  apiUrl             String             @default("https://api.openAI.co")
  company            String             @default("Empresa Demo")
  lat                String             @default("0.0000")
  lng                String             @default("0.0000")
  mapsUrl            String             @default("https://maps.google.com/?q=0,0")
  notificationNumber String             @default("0000000000")
  openingPhrase      String?            @default("DEPRECATED")
  apiKeyId           String?
  del_seguimiento    String?            @default("Estamos para servirle.")
  plan               Plan               @default(pymes)
  autoReactivate     String?
  webhookUrl         String?            @default("https://n8npro.verzay.co/webhook")
  theme              ThemeApp?          @default(Default)
  muteAgentResponses Boolean            @default(false)
  accounts           Account[]
  instancias         Instancias[]
  pausar             Pausar[]
  sessions           Session[]
  systemMessages     SystemMessage[]
  tools              Tools[]
  apiKey             ApiKey?            @relation(fields: [apiKeyId], references: [id])
  iaCredit           IaCredit?
  clientesAsignados  reseller[]         @relation("RevendedorAsignador")
  esClienteDe        reseller[]         @relation("ClienteAsignado")
  modules            Module[]           @relation("UserModules")
  UserAvailability   UserAvailability[]
  Appointment        Appointment[]
  Service            Service[]
}

model Module {
  id                     String       @id @default(cuid())
  label                  String
  route                  String       @unique
  icon                   String
  showInSidebar          Boolean?     @default(true)
  hiddenModuleToSelector Boolean?     @default(false)
  adminOnly              Boolean      @default(false)
  requiresPremium        Boolean      @default(false)
  allowedPlans           Plan[]
  order                  Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  showOnlySelectedPlans  Boolean?     @default(false)
  items                  ModuleItem[] @relation("ParentModule")
  users                  User[]       @relation("UserModules")
}

model ModuleItem {
  id        String   @id @default(cuid())
  title     String
  url       String
  moduleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation("ParentModule", fields: [moduleId], references: [id])
}

model Session {
  userId       String
  remoteJid    String
  pushName     String
  instanceId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  status       Boolean
  id           Int      @id @default(autoincrement())
  seguimientos String?  @default("")
  inactividad  String?  @default("")
  sessionDelay String?
  flujos       String?  @default("")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  Appointment Appointment[]
}

model Pausar {
  userId      String
  mensaje     String   @default("Fue un gusto ayudarte.")
  tipo        String   @default("abrir")
  baseurl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  apikeyId    String
  instanciaId String
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  url       String
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Users     User[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model VerificationToken {
  identifier String   @id @unique
  token      String
  expires    DateTime
}

model Instancias {
  id           Int    @id @default(autoincrement())
  instanceName String
  userId       String
  instanceId   String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemMessage {
  id         String        @id @default(cuid())
  message    String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  title      String        @default("Sin título")
  typePrompt TypePromptAi? @default(TRAINING)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tools {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  definition  String
  status      String
  createdAt   DateTime @default(now())
  updateAt    DateTime @updatedAt
  umbral      Float    @default(0.5)

  @@unique([name, userId])
}

model WorkflowNode {
  id          String   @id @default(cuid())
  workflowId  String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tipo        String
  url         String?
  delay       String?
  inactividad Boolean?
  name_file   String?
  order       String?
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}

model seguimientos {
  id          Int     @id @default(autoincrement())
  idNodo      String
  serverurl   String?
  instancia   String?
  apikey      String?
  remoteJid   String?
  mensaje     String?
  tipo        String?
  time        String?
  name_file   String?
  consecutivo String?
  media       String?
}

model rr {
  id         Int      @id @default(autoincrement())
  workflowId String
  mensaje    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
}

model reseller {
  id         Int      @id @default(autoincrement())
  resellerid String?
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  theme      ThemeApp @default(Default)
  reseller   User?    @relation("RevendedorAsignador", fields: [resellerid], references: [id])
  user       User?    @relation("ClienteAsignado", fields: [userId], references: [id])
}

model GuidesUrl {
  id          String   @id @default(cuid())
  path        String
  title       String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tipo        String?
}

model Manual {
  id          String   @id @default(uuid())
  name        String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  context   String?
  timestamp DateTime @default(now())
}

model IaCredit {
  id          String   @id @default(cuid())
  userId      String   @unique
  total       Int      @default(0)
  used        Int      @default(0)
  renewalDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ia_credits")
}

model Reminders {
  id           String      @id @default(cuid())
  title        String
  description  String?
  time         String?
  repeatType   RepeatType? @default(NONE)
  repeatEvery  Int?
  endsAt       DateTime?
  instanceName String?
  serverUrl    String?
  apikey       String?
  userId       String?
  workflowId   String?
  remoteJid    String?
  pushName     String?
  isSchedule   Boolean?    @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  content     String // Aquí se almacena el texto del prompt
  category    String? // Opcional: ventas, soporte, onboarding, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAvailability {
  id        String @id @default(cuid())
  userId    String
  dayOfWeek Int // 0 (domingo) al 6 (sábado)
  startTime String // ej: "09:00"
  endTime   String // ej: "17:00"
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime, endTime])
}

model Appointment {
  id        String            @id @default(cuid())
  userId    String // Asesor que recibe la cita
  sessionId Int // Cliente que agenda (id de Session)
  startTime DateTime
  endTime   DateTime
  timezone  String
  status    AppointmentStatus @default(PENDIENTE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  serviceId String? // <- NUEVO CAMPO: Motivo de la cita

  service Service? @relation(fields: [serviceId], references: [id])
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  userId      String // para que cada asesor tenga sus propios motivos
  name        String // Nombre visible: "Asesoría", "Reunión de ventas"
  description String? // Opcional para mostrar más info en frontend
  messageText String // Mensaje que se enviará automáticamente por WhatsApp
  createdAt   DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
}

model SessionTrigger {
  id        Int      @id @default(autoincrement())
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessionId String
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  WEEKDAYS
  EVERYDAY
}

enum ThemeApp {
  Default
  Red
  Rose
  Orange
  Green
  Blue
  Yellow
  Violet
  Cyan
  Black
  White
  Teal
  MidnightBlue
  AquaBlue
  LightBlue
}

enum Role {
  user
  admin
  reseller
}

enum Plan {
  empresarial  @map("empresarial")
  business     @map("business")
  pymes        @map("pymes")
  standard     @map("standard")
  intermediate @map("intermediate")
  advanced     @map("advanced")
}

enum TypePromptAi {
  TRAINING
  FAQs
  ACTIONS
  DATA_CAPTURE
  DATA_QUERY
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}
