generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                @id @default(cuid())
  name                          String?
  email                         String                @unique
  password                      String?
  emailVerified                 DateTime?
  image                         String?
  role                          Role                  @default(user)
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  apiUrl                        String                @default("https://api.openAI.co")
  company                       String                @default("Empresa Demo")
  lat                           String                @default("0.0000")
  lng                           String                @default("0.0000")
  mapsUrl                       String                @default("https://maps.google.com/?q=0,0")
  notificationNumber            String                @default("0000000000")
  openingPhrase                 String?               @default("DEPRECATED")
  apiKeyId                      String?
  del_seguimiento               String?               @default("Estamos para servirle.")
  plan                          Plan                  @default(basico)
  autoReactivate                String?
  webhookUrl                    String?               @default("https://n8npro.verzay.co/webhook")
  theme                         ThemeApp?             @default(Default)
  muteAgentResponses            Boolean               @default(false)
  timezone                      String?
  meetingDuration               Int?
  onFacebook                    Boolean               @default(false)
  onInstagram                   Boolean               @default(false)
  accounts                      Account[]
  agentPrompts                  AgentPrompt[]         @relation("UserAgentPrompts")
  publishedAgentPromptRevisions AgentPromptRevision[] @relation("UserPublishedRevisions")
  Appointment                   Appointment[]
  instancias                    Instancias[]
  pausar                        Pausar[]
  PromptInstance                PromptInstance[]
  Service                       Service[]
  sessions                      Session[]
  systemMessages                SystemMessage[]
  tools                         Tools[]
  apiKey                        ApiKey?               @relation(fields: [apiKeyId], references: [id])
  UserAvailability              UserAvailability[]
  iaCredit                      IaCredit?
  clientesAsignados             reseller[]            @relation("RevendedorAsignador")
  esClienteDe                   reseller[]            @relation("ClienteAsignado")
  aiConfig                      UserAiConfig[]
  modules                       Module[]              @relation("UserModules")
}

model AiProvider {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  aiModels    AiModel[]
  configs     UserAiConfig[]

  @@map("ai_providers")
}

model AiModel {
  id          String     @id @default(cuid())
  providerId  String
  name        String
  description String?
  provider    AiProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, name])
  @@map("ai_models")
}

model UserAiConfig {
  id         String     @id @default(cuid())
  userId     String
  providerId String
  apiKey     String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  provider   AiProvider @relation(fields: [providerId], references: [id])
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@map("user_ai_configs")
}

model Module {
  id                     String       @id @default(cuid())
  label                  String
  route                  String
  icon                   String
  showInSidebar          Boolean?     @default(true)
  hiddenModuleToSelector Boolean?     @default(false)
  adminOnly              Boolean      @default(false)
  requiresPremium        Boolean      @default(false)
  allowedPlans           Plan[]
  order                  Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  showOnlySelectedPlans  Boolean?     @default(false)
  customUrl              String?
  items                  ModuleItem[] @relation("ParentModule")
  users                  User[]       @relation("UserModules")
}

model ModuleItem {
  id        String   @id @default(cuid())
  title     String
  url       String
  moduleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation("ParentModule", fields: [moduleId], references: [id])
}

model Session {
  userId       String
  remoteJid    String
  pushName     String
  instanceId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  status       Boolean
  id           Int           @id @default(autoincrement())
  seguimientos String?       @default("")
  inactividad  String?       @default("")
  sessionDelay String?
  flujos       String?       @default("")
  Appointment  Appointment[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pausar {
  userId      String
  mensaje     String   @default("Fue un gusto ayudarte.")
  tipo        String   @default("abrir")
  baseurl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  apikeyId    String
  instanciaId String
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  url       String
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Users     User[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model VerificationToken {
  identifier String   @id @unique
  token      String
  expires    DateTime
}

model Instancias {
  id           Int     @id @default(autoincrement())
  instanceName String
  userId       String
  instanceId   String
  instanceType String? @default("Whatsapp")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromptInstance {
  id           Int     @id @default(autoincrement())
  instanceType String?
  description  String?
  content      String?
  instanceId   Int?
  userId       String
  user         User    @relation(fields: [userId], references: [id])
}

model SystemMessage {
  id         String        @id @default(cuid())
  message    String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  title      String        @default("Sin título")
  typePrompt TypePromptAi? @default(TRAINING)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentPrompt {
  id             String                @id @default(uuid()) @db.Uuid
  userId         String
  agentId        String?
  status         PromptStatus          @default(draft)
  version        Int                   @default(1)
  sections       Json
  promptText     String
  businessName   String?
  businessSector String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation("UserAgentPrompts", fields: [userId], references: [id], onDelete: Cascade)
  revisions      AgentPromptRevision[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([businessName])
  @@index([businessSector])
  @@index([sections], type: Gin)
}

model AgentPromptRevision {
  id                 String      @id @default(uuid()) @db.Uuid
  promptId           String      @db.Uuid
  revisionNumber     Int
  sectionsSnapshot   Json
  promptTextSnapshot String
  publishedBy        String
  publishedAt        DateTime    @default(now())
  notes              String?
  prompt             AgentPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  publishedByUser    User        @relation("UserPublishedRevisions", fields: [publishedBy], references: [id], onDelete: Cascade)

  @@unique([promptId, revisionNumber])
  @@index([publishedAt])
}

model Tools {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  definition  String
  status      String
  createdAt   DateTime @default(now())
  updateAt    DateTime @updatedAt
  umbral      Float    @default(0.5)

  @@unique([name, userId])
}

model WorkflowNode {
  id          String   @id @default(cuid())
  workflowId  String
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tipo        String
  url         String?
  delay       String?
  inactividad Boolean?
  name_file   String?
  order       Int      @default(0)
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}

model seguimientos {
  id          Int     @id @default(autoincrement())
  idNodo      String?
  serverurl   String?
  instancia   String?
  apikey      String?
  remoteJid   String?
  mensaje     String?
  tipo        String?
  time        String?
  name_file   String?
  consecutivo String?
  media       String?
}

model rr {
  id         Int      @id @default(autoincrement())
  workflowId String
  mensaje    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
}

model reseller {
  id         Int      @id @default(autoincrement())
  resellerid String?
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  theme      ThemeApp @default(Default)
  reseller   User?    @relation("RevendedorAsignador", fields: [resellerid], references: [id])
  user       User?    @relation("ClienteAsignado", fields: [userId], references: [id])
}

model GuidesUrl {
  id          String   @id @default(cuid())
  path        String
  title       String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tipo        String?
}

model Manual {
  id          String   @id @default(uuid())
  name        String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  context   String?
  timestamp DateTime @default(now())
}

model IaCredit {
  id          String   @id @default(cuid())
  userId      String   @unique
  total       Int      @default(0)
  used        Int      @default(0)
  renewalDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ia_credits")
}

model Reminders {
  id           String      @id @default(cuid())
  title        String
  description  String?
  time         String?
  repeatType   RepeatType? @default(NONE)
  repeatEvery  Int?
  endsAt       DateTime?
  instanceName String?
  serverUrl    String?
  apikey       String?
  userId       String?
  workflowId   String?
  remoteJid    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  pushName     String?
  isSchedule   Boolean?    @default(false)
}

model PromptTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  content     String
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAvailability {
  id        String @id @default(cuid())
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime, endTime])
}

model Appointment {
  id        String            @id @default(cuid())
  userId    String
  sessionId Int
  startTime DateTime
  endTime   DateTime
  timezone  String
  status    AppointmentStatus @default(PENDIENTE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  serviceId String?
  service   Service?          @relation(fields: [serviceId], references: [id])
  session   Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id           String        @id @default(cuid())
  userId       String
  name         String
  description  String?
  messageText  String
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id])
}

model SessionTrigger {
  id        Int      @id @default(autoincrement())
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessionId String
}

enum PromptStatus {
  draft
  published
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  WEEKDAYS
  EVERYDAY
}

enum ThemeApp {
  Default
  Red
  Rose
  Orange
  Green
  Blue
  Yellow
  Violet
  Cyan
  Black
  White
  Teal
  MidnightBlue
  AquaBlue
  LightBlue
}

enum Role {
  user
  admin
  reseller
}

enum Plan {
  enterprise
  lite
  unico
  basico
  intermedio
  avanzado
  personalizado
}

enum TypePromptAi {
  TRAINING
  FAQs
  ACTIONS
  DATA_CAPTURE
  DATA_QUERY
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}
